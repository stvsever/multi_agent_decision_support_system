  </owl:Class>
  <owl:Ontology rdf:about="https://compass.local/ontology/aomic_id1000#">
    <rdfs:label>COMPASS feature ontology: AOMIC_ID1000</rdfs:label>
    <rdfs:comment>AOMIC ID1000: 928 healthy Dutch young adults. Features span self-report questionnaires (NEO-FFI Big Five personality, BIS/BAS reinforcement sensitivity, STAI trait anxiety), demographics, anthropometrics, socio-economic status, sexual/gender identity ratings, religiosity, plus structural brain morphometry (FreeSurfer subcortical volumes and cortical thickness) and functional connectome (Yeo network connectivity from movie-watching fMRI). Group measures from the same instrument or brain system together; keep brain morphometry and connectome as separate domains.</rdfs:comment>
  </owl:Ontology>
  <owl:AnnotationProperty rdf:about="https://compass.local/ontology/aomic_id1000#sourceColumn">
    <rdfs:label>source column</rdfs:label>
  </owl:AnnotationProperty>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_ANTHROPOMETRICS_biological_traits">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_ANTHROPOMETRICS"/>
    <rdfs:label>Biological Traits</rdfs:label>
    <rdfs:comment>Inherent physiological and physical characteristics of the participant.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_STRUCTURAL_BRAIN_MORPHOMETRY_cortical_thickness_measures">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_STRUCTURAL_BRAIN_MORPHOMETRY"/>
    <rdfs:label>Cortical Thickness Measures</rdfs:label>
    <rdfs:comment>Regional and hemispheric mean cortical thickness estimates derived from structural MRI.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_STRUCTURAL_BRAIN_MORPHOMETRY_subcortical_regional_volumes">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_STRUCTURAL_BRAIN_MORPHOMETRY"/>
    <rdfs:label>Subcortical Regional Volumes</rdfs:label>
    <rdfs:comment>Quantitative volumes of specific subcortical gray matter structures segmented by hemisphere.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_FUNCTIONAL_BRAIN_CONNECTIVITY_between_network_synchrony">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_FUNCTIONAL_BRAIN_CONNECTIVITY"/>
    <rdfs:label>Between-network functional connectivity</rdfs:label>
    <rdfs:comment>Measures of functional synchronization between distinct pairs of Yeo brain networks during movie-watching.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_ANTHROPOMETRICS_socioeconomic_background">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_ANTHROPOMETRICS"/>
    <rdfs:label>Socioeconomic Background</rdfs:label>
    <rdfs:comment>Indicators of the participant's educational attainment and environmental upbringing.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOLOGICAL_CONSTRUCTS_trait_anxiety">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_PSYCHOLOGICAL_CONSTRUCTS"/>
    <rdfs:label>Trait Anxiety</rdfs:label>
    <rdfs:comment>Aggregate measure of stable individual differences in anxiety proneness.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_SYSTEMS_religious_affiliation_and_importance">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF_SYSTEMS"/>
    <rdfs:label>Religious Affiliation and Importance</rdfs:label>
    <rdfs:comment>Self-reported measures regarding religious history, current status, and personal significance of religion.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#PhenotypeFeature">
    <rdfs:label>Phenotype Feature</rdfs:label>
    <rdfs:comment>Root class for all measured participant features.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOLOGICAL_CONSTRUCTS_reinforcement_sensitivity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_PSYCHOLOGICAL_CONSTRUCTS"/>
    <rdfs:label>Reinforcement Sensitivity</rdfs:label>
    <rdfs:comment>Component-level measures of behavioral activation and inhibition systems.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_STRUCTURAL_BRAIN_MORPHOMETRY_global_volumetric_summaries">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_STRUCTURAL_BRAIN_MORPHOMETRY"/>
    <rdfs:label>Global Volumetric Summaries</rdfs:label>
    <rdfs:comment>Aggregate anatomical measures representing total brain tissue and intracranial space volumes.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF_SYSTEMS">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Identity and Belief Systems</rdfs:label>
    <rdfs:comment>Self-reported measures regarding sexual attraction, gender identity, and religious affiliation or importance.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_PSYCHOLOGICAL_CONSTRUCTS">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Psychological Constructs</rdfs:label>
    <rdfs:comment>Self-report questionnaire measures assessing personality traits (NEO-FFI), reinforcement sensitivity (BIS/BAS), and trait anxiety (STAI-T).</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_FUNCTIONAL_BRAIN_CONNECTIVITY_within_network_synchrony">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_FUNCTIONAL_BRAIN_CONNECTIVITY"/>
    <rdfs:label>Within-network functional connectivity</rdfs:label>
    <rdfs:comment>Measures of functional synchronization within individual Yeo brain networks during movie-watching.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_STRUCTURAL_BRAIN_MORPHOMETRY">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Structural Brain Morphometry</rdfs:label>
    <rdfs:comment>Quantitative anatomical measures derived from structural MRI, including global volumetric summaries and regional subcortical volumes and cortical thickness.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_SYSTEMS_sexual_and_gender_identity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF_SYSTEMS"/>
    <rdfs:label>Sexual and Gender Identity</rdfs:label>
    <rdfs:comment>Self-reported measures quantifying sexual attraction and internal gender identity.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_FUNCTIONAL_BRAIN_CONNECTIVITY">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Functional Brain Connectivity</rdfs:label>
    <rdfs:comment>Measures of functional synchronization between Yeo brain networks during movie-watching fMRI, represented as Pearson correlation coefficients.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_ANTHROPOMETRICS">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Demographics and Anthropometrics</rdfs:label>
    <rdfs:comment>Basic biological and socio-economic characteristics of the participants, including age, sex, handedness, BMI, education, and background SES.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOLOGICAL_CONSTRUCTS_personality_traits">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_PSYCHOLOGICAL_CONSTRUCTS"/>
    <rdfs:label>Personality Traits</rdfs:label>
    <rdfs:comment>Aggregate measures of personality traits based on the Five-Factor Model.</rdfs:comment>
  </owl:Class>
</rdf:RDF>
