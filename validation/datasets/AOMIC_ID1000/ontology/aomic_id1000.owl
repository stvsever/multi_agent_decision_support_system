  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_anthropometrics">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_PHYSICAL"/>
    <rdfs:label>Anthropometrics</rdfs:label>
    <rdfs:comment>Quantitative measurements of physical body dimensions such as body mass index.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Identity and Belief</rdfs:label>
    <rdfs:comment>Self-reported measures concerning sexual identity, gender, and religious affiliation.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_sexual_and_gender_identity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF"/>
    <rdfs:label>Sexual and Gender Identity</rdfs:label>
    <rdfs:comment>Self-ratings regarding sexual attraction and gender identity.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_socioeconomic_status">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_PHYSICAL"/>
    <rdfs:label>Socioeconomic Status</rdfs:label>
    <rdfs:comment>Indicators of an individual's social and economic standing, including educational attainment and background.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_BRAIN_CONNECTOME_between_network_connectivity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_BRAIN_CONNECTOME"/>
    <rdfs:label>Between-Network Connectivity</rdfs:label>
    <rdfs:comment>Functional synchronization strength between regions belonging to different functional networks.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_BRAIN_MORPHOMETRY_cortical_thickness">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_BRAIN_MORPHOMETRY"/>
    <rdfs:label>Cortical Thickness</rdfs:label>
    <rdfs:comment>Measurements of the thickness of the cerebral cortex across different lobes and hemispheres.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#PhenotypeFeature">
    <rdfs:label>Phenotype Feature</rdfs:label>
    <rdfs:comment>Root class for all measured participant features.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_PERSONALITY">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Personality Traits</rdfs:label>
    <rdfs:comment>Psychological characteristics describing stable patterns of behavior and temperament.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_PERSONALITY_big_five_personality">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_PERSONALITY"/>
    <rdfs:label>Big Five Personality</rdfs:label>
    <rdfs:comment>Measures of the five core dimensions of personality: openness, conscientiousness, extraversion, agreeableness, and neuroticism.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_MOTIVATION_AND_AFFECT_anxiety_traits">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_MOTIVATION_AND_AFFECT"/>
    <rdfs:label>Anxiety Traits</rdfs:label>
    <rdfs:comment>Assessment of stable individual differences in the tendency to experience anxiety.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_MOTIVATION_AND_AFFECT">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Motivation and Affect</rdfs:label>
    <rdfs:comment>Psychological constructs related to reinforcement sensitivity and emotional regulation.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_BRAIN_CONNECTOME">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Brain Connectome</rdfs:label>
    <rdfs:comment>Functional connectivity patterns between brain networks derived from movie-watching fMRI.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_BRAIN_MORPHOMETRY">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Brain Morphometry</rdfs:label>
    <rdfs:comment>Structural measurements of brain anatomy derived from structural MRI data.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_MOTIVATION_AND_AFFECT_reinforcement_sensitivity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_MOTIVATION_AND_AFFECT"/>
    <rdfs:label>Reinforcement Sensitivity</rdfs:label>
    <rdfs:comment>Measures of behavioral approach and inhibition systems in response to reward and punishment.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_religiosity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF"/>
    <rdfs:label>Religiosity</rdfs:label>
    <rdfs:comment>Measures of religious upbringing, current religious practice, and the personal importance of religion.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_PHYSICAL">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Demographics and Physical Characteristics</rdfs:label>
    <rdfs:comment>Basic biological, physical, and socioeconomic descriptors of the study participants.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_BRAIN_CONNECTOME_within_network_connectivity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_BRAIN_CONNECTOME"/>
    <rdfs:label>Within-Network Connectivity</rdfs:label>
    <rdfs:comment>Functional synchronization strength between regions belonging to the same functional network.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_BRAIN_MORPHOMETRY_subcortical_volumes">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_BRAIN_MORPHOMETRY"/>
    <rdfs:label>Subcortical Volumes</rdfs:label>
    <rdfs:comment>Volumetric measurements of specific deep brain structures such as the hippocampus and amygdala.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_BRAIN_MORPHOMETRY_global_brain_measures">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_BRAIN_MORPHOMETRY"/>
    <rdfs:label>Global Brain Measures</rdfs:label>
    <rdfs:comment>Aggregate volumetric measurements of total brain tissue and major structural compartments.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_personal_attributes">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_PHYSICAL"/>
    <rdfs:label>Personal Attributes</rdfs:label>
    <rdfs:comment>Fundamental demographic identifiers including age, biological sex, and handedness.</rdfs:comment>
  </owl:Class>
</rdf:RDF>
