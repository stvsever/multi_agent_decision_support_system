{
  "domains": [
    {
      "id": "DEMOGRAPHICS_AND_ANTHROPOMETRICS",
      "label": "Demographics and Anthropometrics",
      "definition": "Basic biological and socio-economic characteristics of the participants, including age, sex, handedness, BMI, education, and background SES.",
      "subdomains": [
        {
          "id": "biological_traits",
          "label": "Biological Traits",
          "definition": "Inherent physiological and physical characteristics of the participant.",
          "features": [
            {
              "id": "age",
              "label": "Age",
              "definition": "Age of participant in years.",
              "stat_type": "numeric",
              "units": "years"
            },
            {
              "id": "sex",
              "label": "Biological sex",
              "definition": "Self-reported biological sex (male/female).",
              "stat_type": "binary",
              "units": null
            },
            {
              "id": "handedness",
              "label": "Handedness",
              "definition": "Left- or right-handed.",
              "stat_type": "binary",
              "units": null
            },
            {
              "id": "BMI",
              "label": "Body mass index",
              "definition": "Body mass index (kg/m^2). Zero values are data errors and treated as missing.",
              "stat_type": "numeric",
              "units": "kg/m^2"
            }
          ]
        },
        {
          "id": "socioeconomic_background",
          "label": "Socioeconomic Background",
          "definition": "Indicators of the participant's educational attainment and environmental upbringing.",
          "features": [
            {
              "id": "education_level",
              "label": "Education level",
              "definition": "Highest completed education level (CBS classification): low/medium/high.",
              "stat_type": "ordinal",
              "units": null
            },
            {
              "id": "background_SES",
              "label": "Background socio-economic status",
              "definition": "Background SES from parental income and education (range 2-6).",
              "stat_type": "numeric",
              "units": null
            }
          ]
        }
      ]
    },
    {
      "id": "PSYCHOLOGICAL_CONSTRUCTS",
      "label": "Psychological Constructs",
      "definition": "Self-report questionnaire measures assessing personality traits (NEO-FFI), reinforcement sensitivity (BIS/BAS), and trait anxiety (STAI-T).",
      "subdomains": [
        {
          "id": "personality_traits",
          "label": "Personality Traits",
          "definition": "Aggregate measures of personality traits based on the Five-Factor Model.",
          "features": [
            {
              "id": "NEO_N",
              "label": "Neuroticism (NEO-FFI)",
              "definition": "NEO-FFI Neuroticism scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "NEO_E",
              "label": "Extraversion (NEO-FFI)",
              "definition": "NEO-FFI Extraversion scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "NEO_O",
              "label": "Openness (NEO-FFI)",
              "definition": "NEO-FFI Openness to experience scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "NEO_A",
              "label": "Agreeableness (NEO-FFI)",
              "definition": "NEO-FFI Agreeableness scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "NEO_C",
              "label": "Conscientiousness (NEO-FFI)",
              "definition": "NEO-FFI Conscientiousness scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            }
          ]
        },
        {
          "id": "reinforcement_sensitivity",
          "label": "Reinforcement Sensitivity",
          "definition": "Component-level measures of behavioral activation and inhibition systems.",
          "features": [
            {
              "id": "BAS_drive",
              "label": "BAS drive",
              "definition": "Behavioural Activation System drive subscale.",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "BAS_fun",
              "label": "BAS fun-seeking",
              "definition": "Behavioural Activation System fun-seeking subscale.",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "BAS_reward",
              "label": "BAS reward responsiveness",
              "definition": "Behavioural Activation System reward responsiveness subscale.",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "BIS",
              "label": "Behavioural inhibition (BIS)",
              "definition": "Behavioural Inhibition System scale.",
              "stat_type": "numeric",
              "units": null
            }
          ]
        },
        {
          "id": "trait_anxiety",
          "label": "Trait Anxiety",
          "definition": "Aggregate measure of stable individual differences in anxiety proneness.",
          "features": [
            {
              "id": "STAI_T",
              "label": "Trait anxiety (STAI-T)",
              "definition": "State-Trait Anxiety Inventory, trait subscale.",
              "stat_type": "numeric",
              "units": null
            }
          ]
        }
      ]
    },
    {
      "id": "IDENTITY_AND_BELIEF_SYSTEMS",
      "label": "Identity and Belief Systems",
      "definition": "Self-reported measures regarding sexual attraction, gender identity, and religious affiliation or importance.",
      "subdomains": [
        {
          "id": "sexual_and_gender_identity",
          "label": "Sexual and Gender Identity",
          "definition": "Self-reported measures quantifying sexual attraction and internal gender identity.",
          "features": [
            {
              "id": "sexual_attraction_M",
              "label": "Sexual attraction to males",
              "definition": "Degree of sexual attraction to males (1-7).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "sexual_attraction_F",
              "label": "Sexual attraction to females",
              "definition": "Degree of sexual attraction to females (1-7).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "gender_identity_M",
              "label": "Gender identity (male)",
              "definition": "Degree to which the subject felt male (1-7).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "gender_identity_F",
              "label": "Gender identity (female)",
              "definition": "Degree to which the subject felt female (1-7).",
              "stat_type": "numeric",
              "units": null
            }
          ]
        },
        {
          "id": "religious_affiliation_and_importance",
          "label": "Religious Affiliation and Importance",
          "definition": "Self-reported measures regarding religious history, current status, and personal significance of religion.",
          "features": [
            {
              "id": "religious_upbringing",
              "label": "Religious upbringing",
              "definition": "Whether the subject had a religious upbringing (yes/no).",
              "stat_type": "binary",
              "units": null
            },
            {
              "id": "religious_now",
              "label": "Currently religious",
              "definition": "Whether the subject is religious now (yes/no).",
              "stat_type": "binary",
              "units": null
            },
            {
              "id": "religious_importance",
              "label": "Importance of religion",
              "definition": "How much religion plays a role in the subject's life (1-5).",
              "stat_type": "numeric",
              "units": null
            }
          ]
        }
      ]
    },
