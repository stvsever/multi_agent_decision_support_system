{
  "domains": [
    {
      "id": "DEMOGRAPHICS_AND_PHYSICAL",
      "label": "Demographics and Physical Characteristics",
      "definition": "Basic biographical, physical, and socioeconomic data describing the individual participant.",
      "subdomains": [
        {
          "id": "personal_attributes",
          "label": "Personal Attributes",
          "definition": "Core biological and developmental identifiers including age, sex, and handedness.",
          "features": [
            {
              "id": "age",
              "label": "Age",
              "definition": "Age of participant in years.",
              "stat_type": "numeric",
              "units": "years"
            },
            {
              "id": "sex",
              "label": "Biological sex",
              "definition": "Self-reported biological sex (male/female).",
              "stat_type": "binary",
              "units": null
            },
            {
              "id": "handedness",
              "label": "Handedness",
              "definition": "Left- or right-handed.",
              "stat_type": "binary",
              "units": null
            }
          ]
        },
        {
          "id": "anthropometrics",
          "label": "Anthropometrics",
          "definition": "Quantitative measurements of physical body dimensions and composition.",
          "features": [
            {
              "id": "BMI",
              "label": "Body mass index",
              "definition": "Body mass index (kg/m^2). Zero values are data errors and treated as missing.",
              "stat_type": "numeric",
              "units": "kg/m^2"
            }
          ]
        },
        {
          "id": "socioeconomic_status",
          "label": "Socioeconomic Status",
          "definition": "Indicators of an individual's educational attainment and social or economic background.",
          "features": [
            {
              "id": "education_level",
              "label": "Education level",
              "definition": "Highest completed education level (CBS classification): low/medium/high.",
              "stat_type": "ordinal",
              "units": null
            },
            {
              "id": "background_SES",
              "label": "Background socio-economic status",
              "definition": "Background SES from parental income and education (range 2-6).",
              "stat_type": "numeric",
              "units": null
            }
          ]
        }
      ]
    },
    {
      "id": "PERSONALITY",
      "label": "Personality Traits",
      "definition": "Stable patterns of behavior, thought, and emotion as measured by standardized personality assessments.",
      "subdomains": [
        {
          "id": "big_five_personality",
          "label": "Big Five Personality",
          "definition": "Measures of the five broad dimensions of personality: Neuroticism, Extraversion, Openness, Agreeableness, and Conscientiousness.",
          "features": [
            {
              "id": "NEO_N",
              "label": "Neuroticism (NEO-FFI)",
              "definition": "NEO-FFI Neuroticism scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "NEO_E",
              "label": "Extraversion (NEO-FFI)",
              "definition": "NEO-FFI Extraversion scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "NEO_O",
              "label": "Openness (NEO-FFI)",
              "definition": "NEO-FFI Openness to experience scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "NEO_A",
              "label": "Agreeableness (NEO-FFI)",
              "definition": "NEO-FFI Agreeableness scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "NEO_C",
              "label": "Conscientiousness (NEO-FFI)",
              "definition": "NEO-FFI Conscientiousness scale (sum of items).",
              "stat_type": "numeric",
              "units": null
            }
          ]
        }
      ]
    },
    {
      "id": "MOTIVATION_AND_AFFECT",
      "label": "Motivation and Affect",
      "definition": "Psychological constructs related to reinforcement sensitivity and emotional regulation.",
      "subdomains": [
        {
          "id": "reinforcement_sensitivity",
          "label": "Reinforcement Sensitivity",
          "definition": "Measures of behavioral approach and inhibition systems in response to reward and punishment stimuli.",
          "features": [
            {
              "id": "BAS_drive",
              "label": "BAS drive",
              "definition": "Behavioural Activation System drive subscale.",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "BAS_fun",
              "label": "BAS fun-seeking",
              "definition": "Behavioural Activation System fun-seeking subscale.",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "BAS_reward",
              "label": "BAS reward responsiveness",
              "definition": "Behavioural Activation System reward responsiveness subscale.",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "BIS",
              "label": "Behavioural inhibition (BIS)",
              "definition": "Behavioural Inhibition System scale.",
              "stat_type": "numeric",
              "units": null
            }
          ]
        },
        {
          "id": "anxiety_traits",
          "label": "Anxiety Traits",
          "definition": "Assessment of stable, long-term tendencies toward experiencing anxiety.",
          "features": [
            {
              "id": "STAI_T",
              "label": "Trait anxiety (STAI-T)",
              "definition": "State-Trait Anxiety Inventory, trait subscale.",
              "stat_type": "numeric",
              "units": null
            }
          ]
        }
      ]
    },
    {
      "id": "IDENTITY_AND_BELIEF",
      "label": "Identity and Belief",
      "definition": "Self-reported measures concerning sexual orientation, gender identity, and religious affiliation.",
      "subdomains": [
        {
          "id": "sexual_and_gender_identity",
          "label": "Sexual and Gender Identity",
          "definition": "Ratings reflecting an individual's sexual attraction patterns and gender self-identification.",
          "features": [
            {
              "id": "sexual_attraction_M",
              "label": "Sexual attraction to males",
              "definition": "",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "sexual_attraction_F",
              "label": "Sexual attraction to females",
              "definition": "",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "gender_identity_M",
              "label": "Gender identity (male)",
              "definition": "Degree to which the subject felt male (1-7).",
              "stat_type": "numeric",
              "units": null
            },
            {
              "id": "gender_identity_F",
              "label": "Gender identity (female)",
              "definition": "Degree to which the subject felt female (1-7).",
              "stat_type": "numeric",
              "units": null
            }
          ]
        },
        {
          "id": "religiosity",
          "label": "Religiosity",
          "definition": "Measures of an individual's religious upbringing, current practice, and the perceived importance of faith.",
          "features": [
            {
              "id": "religious_upbringing",
              "label": "Religious upbringing",
              "definition": "Whether the subject had a religious upbringing (yes/no).",
              "stat_type": "binary",
              "units": null
            },
            {
              "id": "religious_now",
              "label": "Currently religious",
              "definition": "Whether the subject is religious now (yes/no).",
              "stat_type": "binary",
              "units": null
            },
            {
              "id": "religious_importance",
              "label": "Importance of religion",
              "definition": "How much religion plays a role in the subject's life (1-5).",
              "stat_type": "numeric",
              "units": null
            }
          ]
        }
      ]
    },
