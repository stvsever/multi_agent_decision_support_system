<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns="https://compass.local/ontology/aomic_id1000#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_gender_identity_F">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_sexual_and_gender_identity"/>
    <rdfs:label>Gender identity (female)</rdfs:label>
    <rdfs:comment>Degree to which the subject felt female (1-7).</rdfs:comment>
    <sourceColumn>gender_identity_F</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_age">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_personal_attributes"/>
    <rdfs:label>Age</rdfs:label>
    <rdfs:comment>Age of participant in years.</rdfs:comment>
    <sourceColumn>age</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_NEO_C">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_big_five_personality"/>
    <rdfs:label>Conscientiousness (NEO-FFI)</rdfs:label>
    <rdfs:comment>NEO-FFI Conscientiousness scale (sum of items).</rdfs:comment>
    <sourceColumn>NEO_C</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_sexual_attraction_M">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_sexual_and_gender_identity"/>
    <rdfs:label>Sexual attraction to males</rdfs:label>
    <rdfs:comment>Degree of sexual attraction to males (1-7).</rdfs:comment>
    <sourceColumn>sexual_attraction_M</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_religious_upbringing">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_religiosity"/>
    <rdfs:label>Religious upbringing</rdfs:label>
    <rdfs:comment>Whether the subject had a religious upbringing (yes/no).</rdfs:comment>
    <sourceColumn>religious_upbringing</sourceColumn>
    <statType>binary</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_sexual_attraction_F">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_sexual_and_gender_identity"/>
    <rdfs:label>Sexual attraction to females</rdfs:label>
    <rdfs:comment>Degree of sexual attraction to females (1-7).</rdfs:comment>
    <sourceColumn>sexual_attraction_F</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_NEO_N">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_big_five_personality"/>
    <rdfs:label>Neuroticism (NEO-FFI)</rdfs:label>
    <rdfs:comment>NEO-FFI Neuroticism scale (sum of items).</rdfs:comment>
    <sourceColumn>NEO_N</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_religious_importance">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_religiosity"/>
    <rdfs:label>Importance of religion</rdfs:label>
    <rdfs:comment>How much religion plays a role in the subject's life (1-5).</rdfs:comment>
    <sourceColumn>religious_importance</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_handedness">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_personal_attributes"/>
    <rdfs:label>Handedness</rdfs:label>
    <rdfs:comment>Left- or right-handed.</rdfs:comment>
    <sourceColumn>handedness</sourceColumn>
    <statType>binary</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_BIS">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_reinforcement_sensitivity"/>
    <rdfs:label>Behavioural inhibition (BIS)</rdfs:label>
    <rdfs:comment>Behavioural Inhibition System scale.</rdfs:comment>
    <sourceColumn>BIS</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_gender_identity_M">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_sexual_and_gender_identity"/>
    <rdfs:label>Gender identity (male)</rdfs:label>
    <rdfs:comment>Degree to which the subject felt male (1-7).</rdfs:comment>
    <sourceColumn>gender_identity_M</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:AnnotationProperty rdf:about="https://compass.local/ontology/aomic_id1000#sourceColumn">
    <rdfs:label>source column</rdfs:label>
  </owl:AnnotationProperty>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_background_SES">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_socioeconomic_status"/>
    <rdfs:label>Background socio-economic status</rdfs:label>
    <rdfs:comment>Background SES from parental income and education (range 2-6).</rdfs:comment>
    <sourceColumn>background_SES</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_BAS_drive">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_reinforcement_sensitivity"/>
    <rdfs:label>BAS drive</rdfs:label>
    <rdfs:comment>Behavioural Activation System drive subscale.</rdfs:comment>
    <sourceColumn>BAS_drive</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_NEO_E">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_big_five_personality"/>
    <rdfs:label>Extraversion (NEO-FFI)</rdfs:label>
    <rdfs:comment>NEO-FFI Extraversion scale (sum of items).</rdfs:comment>
    <sourceColumn>NEO_E</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_BAS_reward">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_reinforcement_sensitivity"/>
    <rdfs:label>BAS reward responsiveness</rdfs:label>
    <rdfs:comment>Behavioural Activation System reward responsiveness subscale.</rdfs:comment>
    <sourceColumn>BAS_reward</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_religious_now">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_religiosity"/>
    <rdfs:label>Currently religious</rdfs:label>
    <rdfs:comment>Whether the subject is religious now (yes/no).</rdfs:comment>
    <sourceColumn>religious_now</sourceColumn>
    <statType>binary</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_education_level">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_socioeconomic_status"/>
    <rdfs:label>Education level</rdfs:label>
    <rdfs:comment>Highest completed education level (CBS classification): low/medium/high.</rdfs:comment>
    <sourceColumn>education_level</sourceColumn>
    <statType>ordinal</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_NEO_A">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_big_five_personality"/>
    <rdfs:label>Agreeableness (NEO-FFI)</rdfs:label>
    <rdfs:comment>NEO-FFI Agreeableness scale (sum of items).</rdfs:comment>
    <sourceColumn>NEO_A</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_sex">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_personal_attributes"/>
    <rdfs:label>Biological sex</rdfs:label>
    <rdfs:comment>Self-reported biological sex (male/female).</rdfs:comment>
    <sourceColumn>sex</sourceColumn>
    <statType>binary</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_STAI_T">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_anxiety_traits"/>
    <rdfs:label>Trait anxiety (STAI-T)</rdfs:label>
    <rdfs:comment>State-Trait Anxiety Inventory, trait subscale.</rdfs:comment>
    <sourceColumn>STAI_T</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_BAS_fun">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_reinforcement_sensitivity"/>
    <rdfs:label>BAS fun-seeking</rdfs:label>
    <rdfs:comment>Behavioural Activation System fun-seeking subscale.</rdfs:comment>
    <sourceColumn>BAS_fun</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_NEO_O">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_big_five_personality"/>
    <rdfs:label>Openness (NEO-FFI)</rdfs:label>
    <rdfs:comment>NEO-FFI Openness to experience scale (sum of items).</rdfs:comment>
    <sourceColumn>NEO_O</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:Ontology rdf:about="https://compass.local/ontology/aomic_id1000#">
    <rdfs:label>COMPASS feature ontology: AOMIC_ID1000</rdfs:label>
    <rdfs:comment>AOMIC ID1000: 928 healthy Dutch young adults. Features are self-report questionnaire scores (NEO-FFI Big Five personality, BIS/BAS reinforcement sensitivity, STAI trait anxiety), demographics, anthropometrics, socio-economic status, sexual/gender identity ratings, and religiosity. Group scales from the same instrument together.</rdfs:comment>
  </owl:Ontology>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#FEATURE_BMI">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_personal_attributes"/>
    <rdfs:label>Body mass index</rdfs:label>
    <rdfs:comment>Body mass index (kg/m^2). Zero values are data errors and treated as missing.</rdfs:comment>
    <sourceColumn>BMI</sourceColumn>
    <statType>numeric</statType>
  </owl:Class>
  <owl:AnnotationProperty rdf:about="https://compass.local/ontology/aomic_id1000#statType">
    <rdfs:label>statistical type</rdfs:label>
  </owl:AnnotationProperty>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_anxiety_traits">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_PSYCHOMETRIC_PROFILES"/>
    <rdfs:label>Anxiety Traits</rdfs:label>
    <rdfs:comment>Scores from the STAI-T inventory measuring stable trait anxiety.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Identity and Belief Systems</rdfs:label>
    <rdfs:comment>Self-reported ratings regarding sexual orientation, gender identity, and religious affiliation.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_reinforcement_sensitivity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_PSYCHOMETRIC_PROFILES"/>
    <rdfs:label>Reinforcement Sensitivity</rdfs:label>
    <rdfs:comment>Scores from the BIS/BAS scales measuring behavioral inhibition and activation systems.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_socioeconomic_status">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_PHYSICAL"/>
    <rdfs:label>Socioeconomic Status</rdfs:label>
    <rdfs:comment>Indicators of educational attainment and family background.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_PHYSICAL">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Demographics and Physical Characteristics</rdfs:label>
    <rdfs:comment>Basic biological, physical, and socio-economic attributes of the participants.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#PhenotypeFeature">
    <rdfs:label>Phenotype Feature</rdfs:label>
    <rdfs:comment>Root class for all measured participant features.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_sexual_and_gender_identity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF"/>
    <rdfs:label>Sexual and Gender Identity</rdfs:label>
    <rdfs:comment>Subjective ratings of sexual attraction and gender identification.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_DEMOGRAPHICS_AND_PHYSICAL_personal_attributes">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_DEMOGRAPHICS_AND_PHYSICAL"/>
    <rdfs:label>Personal Attributes</rdfs:label>
    <rdfs:comment>Core demographic and physical identifiers of the individual.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_IDENTITY_AND_BELIEF_religiosity">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_IDENTITY_AND_BELIEF"/>
    <rdfs:label>Religiosity</rdfs:label>
    <rdfs:comment>Measures of religious upbringing, current practice, and personal importance of faith.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#DOMAIN_PSYCHOMETRIC_PROFILES">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#PhenotypeFeature"/>
    <rdfs:label>Psychometric Profiles</rdfs:label>
    <rdfs:comment>Standardized questionnaire scores measuring personality, motivation, and anxiety.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="https://compass.local/ontology/aomic_id1000#SUB_PSYCHOMETRIC_PROFILES_big_five_personality">
    <rdfs:subClassOf rdf:resource="https://compass.local/ontology/aomic_id1000#DOMAIN_PSYCHOMETRIC_PROFILES"/>
    <rdfs:label>Big Five Personality</rdfs:label>
    <rdfs:comment>Scores from the NEO-FFI inventory assessing the five-factor model of personality.</rdfs:comment>
  </owl:Class>
</rdf:RDF>
