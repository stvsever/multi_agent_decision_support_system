# Required for the default OpenRouter backend
OPENROUTER_API_KEY=

# Optional OpenRouter request metadata
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=COMPASS

# Optional. Required only when selecting the OpenAI backend directly
OPENAI_API_KEY=

# Runtime defaults
EMBEDDING_MODEL=text-embedding-3-large
COMPASS_UI_HOST=127.0.0.1
COMPASS_UI_PORT=5005
